# Mixpanel 프로젝트 토큰. 비워두면 이벤트는 콘솔에만 로그되고 전송되지 않습니다.
NEXT_PUBLIC_MIXPANEL_TOKEN=

# 카카오 개발자 콘솔(https://developers.kakao.com) > 내 애플리케이션 > 앱 키의 "JavaScript 키".
# 비워두면 지도 탭에 안내 화면만 뜨고 지도는 표시되지 않습니다.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 카카오 개발자 콘솔 > 앱 키의 "REST API 키". 식당 데이터 일괄 조회 스크립트(scripts/) 전용이라
# 앱 실행에는 필요 없다. NEXT_PUBLIC_ 접두사가 없으므로 클라이언트 번들에 절대 포함되지 않는다.
KAKAO_REST_API_KEY=
